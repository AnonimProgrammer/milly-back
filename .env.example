# Copy to .env and fill in values for local development / Docker Compose.
# .env is gitignored; this file documents the full env contract.

# PostgreSQL (required for dev)
DATABASE_URL=jdbc:postgresql://localhost:5432/milly
DATABASE_USERNAME=milly
DATABASE_PASSWORD=milly

# JWT (optional in dev — application.properties provides a local default)
JWT_SECRET=dev-jwt-secret-with-at-least-sixty-four-characters-for-hmac-signing

# JWT TTLs (optional)
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=1209600

# OAuth client IDs (required when using the respective provider)
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# Server (optional)
SERVER_PORT=8080

# Client app base URL (optional in dev)
CLIENT_URL=http://localhost:3000

# Amazon S3 (required when using blob storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=eu-west-1
# Leave empty to use https://{bucket}.s3.{region}.amazonaws.com/{key}
# Only set when using CloudFront or a custom CDN domain, e.g. https://cdn.example.com
S3_PUBLIC_BASE_URL=

# AI (optional — disabled by default)
AI_ENABLED=false
OPENROUTER_API_KEY=
AI_MODEL=google/gemini-2.5-flash
AI_MAX_TOKENS=2048

OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_APP_TITLE=Milly

# AI circuit breaker (optional — used when AI_ENABLED=true)
AI_CIRCUIT_BREAKER_FAILURE_RATE_THRESHOLD=50
AI_CIRCUIT_BREAKER_WAIT_DURATION_SECONDS=30
AI_CIRCUIT_BREAKER_SLIDING_WINDOW_SIZE=10
AI_CIRCUIT_BREAKER_MINIMUM_NUMBER_OF_CALLS=3

# Caffeine (optional — application.properties provides defaults)
# CACHE_DEFAULT_MAXIMUM_SIZE=10000