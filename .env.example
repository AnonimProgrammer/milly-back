# Copy to .env and fill in values for local development / Docker Compose.
# .env is gitignored; this file documents the full env contract.

# PostgreSQL (required for dev)
DATABASE_URL=jdbc:postgresql://localhost:5432/milly
DATABASE_USERNAME=milly
DATABASE_PASSWORD=milly

# JWT (optional in dev — application.properties provides a local default)
JWT_SECRET=dev-jwt-secret-with-at-least-sixty-four-characters-for-hmac-signing

# JWT TTLs (optional)
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=1209600

# OAuth client IDs (required when using the respective provider)
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# Server (optional)
SERVER_PORT=8080

# Caffeine (optional — application.properties provides defaults)
# CACHE_DEFAULT_MAXIMUM_SIZE=10000
