meta {
  name: Register venue
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/venues
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "name": "Milly Bistro",
    "location": "Barcelona, Spain"
  }
}

docs {
  Run after authentication so the cookie jar sends `access-token` automatically.
  The authenticated user becomes the venue's Manager.
}
