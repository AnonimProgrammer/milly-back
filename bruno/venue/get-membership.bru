meta {
  name: Get venue membership
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/v1/venues/{{venueId}}/me
  body: none
  auth: none
}

headers {
  Accept: application/json
}

docs {
  Prerequisites:
  1. Run **Continue — login (password)** so Bruno stores auth cookies.
  2. Set `venueId` in the local environment to `data.id` from **Register venue** (or any venue you belong to).

  Without a valid `venueId`, the URL becomes `/api/v1/venues//me` and the request will fail.
}
