meta {
  name: Get bill
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/api/v1/public/tables/{{testTableId}}/orders/{{testOrderId}}/bill
  body: none
  auth: none
}

settings {
  encodeUrl: true
  timeout: 0
}

docs {
  Returns orderTotal, paidAmount, remaining, fullyPaid, and the list of COMPLETED payments
  for the order.
}