meta {
  name: Estimate preparation time (AI)
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/api/v1/venues/{{testVenueId}}/orders/{{testOrderId}}/preparation-time/estimate
  body: none
  auth: inherit
}

headers {
