meta {
  name: Create table
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/venues/{{venueId}}/tables
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "label": "Table 1"
  }
}

script:post-response {
  const json = res.getBody();
  if (json?.data?.id) {
    bru.setEnvVar('testTableId', json.data.id);
    bru.setEnvVar('tableId', json.data.id);
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
