meta {
  name: Continue — login (password)
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/auth/continue
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "provider": "PASSWORD",
    "credentials": {
      "email": "{{testEmail}}",
      "password": "{{testPassword}}"
    }
  }
}
